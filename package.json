{
  "name": "silversprint",
  "version": "1.0.2",
  "description": "SilverSprint racing display for Raspberry Pi",
  "main": "electron-main.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "electron": "electron .",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "express": "^4.18.0",
    "serialport": "^12.0.0",
    "ws": "^8.0.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.silversprint.app",
    "productName": "SilverSprints",
    "files": [
      "electron-main.js",
      "server.js",
      "src/**",
      "public/**"
    ],
    "mac": {
      "category": "public.app-category.sports",
      "target": "dmg"
    },
    "win": {
      "target": {
        "target": "nsis",
        "arch": "x64"
      }
    }
  }
}
